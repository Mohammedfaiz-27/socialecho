# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/socialecho

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=socialecho
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ── Social Media APIs ────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
# RapidAPI host for Facebook scraper (subscribe: facebook-scraper-api4.p.rapidapi.com)
FACEBOOK_RAPIDAPI_HOST=facebook-scraper-api4.p.rapidapi.com

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
# RapidAPI host for Instagram scraper (subscribe: instagram-looter2.p.rapidapi.com)
INSTAGRAM_RAPIDAPI_HOST=instagram-looter2.p.rapidapi.com

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── AI / NLP ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@socialecho.com

# ── Collection Toggles ───────────────────────────────────────────────────────
ENABLE_AUTO_COLLECTION=true
ENABLE_NEWS_COLLECTION=true
ENABLE_FACEBOOK_COLLECTION=true
ENABLE_INSTAGRAM_COLLECTION=true
DATA_COLLECTION_INTERVAL_MINUTES=15

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_STANDARD=1000
RATE_LIMIT_MAX_PREMIUM=10000
